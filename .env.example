# ============================================================
# Sentinel — Environment Variables
# Use the setup wizard at docs/index.html for guided setup.
# Copy this file to .env and fill in your values manually,
# or generate a filled .env directly from the wizard.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Public.com (REQUIRED)
# Generate at: public.com → Account Settings → Security → API
# ----------------------------------------------------------
PUBLIC_API_SECRET=your_public_api_key_here
PUBLIC_ACCOUNT_ID=your_account_id_here        # e.g. 5OP12345

# ----------------------------------------------------------
# Anthropic (REQUIRED — Claude agent trade decisions)
# Get at: console.anthropic.com
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# Market data sources (at least one required)
# All have free tiers sufficient for the bot
# ----------------------------------------------------------

# Polygon.io — news sentiment + previous close data
# Free: https://polygon.io (unlimited historical, 5 req/min)
POLYGON_API_KEY=your_polygon_key_here

# Finnhub — pre-computed news sentiment + EPS surprises
# Free: https://finnhub.io (60 req/min, no daily cap)
FINNHUB_API_KEY=your_finnhub_key_here

# MarketAux — entity-level news sentiment
# Free: https://www.marketaux.com (100 req/day)
MARKETAUX_API_KEY=your_marketaux_key_here

# NewsAPI — macro headline scoring via Claude
# Free: https://newsapi.org (100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage — earnings calendar (earnings proximity modifier)
# Free: https://www.alphavantage.co (25 req/day)
ALPHA_VANTAGE_API_KEY=your_av_key_here

# ----------------------------------------------------------
# AWS (required for autonomous Lambda deployment)
# ----------------------------------------------------------
AWS_REGION=us-east-2
AWS_SECRET_NAME=trading-bot/secrets           # Secrets Manager secret name
SNS_TOPIC_ARN=arn:aws:sns:us-east-2:YOUR_ACCOUNT:Sentinel

# Human-in-the-loop approval links (HMAC-signed emails)
SUGGESTION_TOKEN_SECRET=your_random_secret_here   # generate: openssl rand -hex 32
LAMBDA_FUNCTION_URL=https://YOUR_API_GATEWAY_URL  # API Gateway URL for /approve endpoint

# ----------------------------------------------------------
# Watchlist & Blocklist (tiered — controls directional bias)
# ----------------------------------------------------------

# WATCHLIST_BEARISH — puts only. Bot will only buy puts on these tickers when
# the sentiment score is ≤ -0.35. Never buys calls or stock here.
WATCHLIST_BEARISH=RIVN,INTC,SOFI,PFE,MRNA,F,VXX

# WATCHLIST_BULLISH — calls only. Bot will only buy calls (or stock) on these
# tickers when sentiment is bullish. Never buys puts here.
WATCHLIST_BULLISH=XLE,OXY,BNO,LMT,RTX

# WATCHLIST_NEUTRAL — signal-driven. Calls on bullish signals, puts on bearish
# (≤ -0.35). Standard behavior.
WATCHLIST_NEUTRAL=AAPL,MSFT,NVDA,AMD,META,AMZN,GOOGL,SPY,QQQ,BAC,C

# BLACKLIST — comma-separated tickers permanently excluded from scanning and trading.
# Useful for tickers you hold long-term or never want the bot to touch.
BLACKLIST=X,LYFT,SNAP,PLTR

# ----------------------------------------------------------
# User risk profile (optional — sensible defaults provided)
# ----------------------------------------------------------

# Risk tolerance: conservative | moderate | aggressive
RISK_TOLERANCE=moderate

# Enable/disable call option orders
OPTIONS_CALLS_ENABLED=true

# Require human approval before any sell executes (recommended while getting started)
REQUIRE_SELL_APPROVAL=false

# Kill switch — set true to halt ALL trading immediately (no redeploy needed)
TRADING_PAUSED=false

# ----------------------------------------------------------
# Carpet Bagger — Kalshi sports prediction markets (optional)
# ----------------------------------------------------------
CARPET_BAGGER_ENABLED=true
CARPET_BAGGER_MAX_POSITION=1.00   # max $ per game (avoid overnight lockup)

# Bracket Buster — tournament tree arbitrage on Kalshi (NCAA March Madness etc.)
# Start false and paper-trade first to validate arb detection before going live
BRACKET_BUSTER_ENABLED=false
BRACKET_BUSTER_MAX_POSITION=5.00  # max $ per arb position

# Kalshi API credentials — get at kalshi.com → Settings → API
KALSHI_API_KEY=your_kalshi_api_key_here

# RSA private key: paste as a single quoted line with \n for newlines
KALSHI_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"

# ----------------------------------------------------------
# Macro position monitor (EOD email — optional)
# If you manually placed a stock + call thesis trade, the EOD
# email will include live P&L for it. Set the tickers here.
# ----------------------------------------------------------
MACRO_TRADE_STOCK_TICKER=XLE   # stock leg ticker (default XLE)
MACRO_TRADE_CALL_TICKER=OXY    # call option underlying (default OXY)

# ----------------------------------------------------------
# Macro Trader — Kalshi economic prediction market bridge
# Reuses existing KALSHI_API_KEY / KALSHI_RSA_PRIVATE_KEY above
# ----------------------------------------------------------
MACRO_TRADER_ENABLED=false          # flip true after first few SNS scan summaries look correct
MACRO_TRADER_MAX_POSITION=10.00     # max USD per Kalshi market position
MACRO_TRADER_MIN_SIGNAL=0.50        # min abs(signal) to consider a trade
MACRO_TRADER_MIN_CONFIDENCE=0.65    # min Claude confidence to act
MACRO_TRADER_MIN_EDGE=0.08          # min probability edge vs. market price
MACRO_TRADER_MAX_BID_ASK_SPREAD=0.05

# DynamoDB table names (created automatically by deploy.sh)
MACRO_SIGNAL_CACHE_TABLE=macro-signal-cache
MACRO_OPPORTUNITIES_TABLE=macro-opportunities
MACRO_POSITIONS_TABLE=macro-positions

# ----------------------------------------------------------
# Coinbase Advanced API (funding_rate module — perpetual futures arb)
# Get at: coinbase.com → Settings → API → Create API Key (Advanced Trade)
# ----------------------------------------------------------
COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/yyy
COINBASE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# Funding rate strategy — dormant (Coinbase basis arb requires futures, not available on Public)
FUNDING_RATE_ENABLED=false
FUNDING_RATE_MAX_POSITION=100.00    # max USD per delta-neutral position
FUNDING_RATE_MIN_APR=0.10           # enter when annualized rate > 10%
FUNDING_RATE_EXIT_APR=0.05          # exit when annualized rate drops < 5%

# ----------------------------------------------------------
# Spot crypto via Public.com (custodied through Zero Hash)
# No additional API key required — uses PUBLIC_API_SECRET above
# ----------------------------------------------------------
CRYPTO_ENABLED=true

# ----------------------------------------------------------
# Political Trader — Kalshi political prediction markets
# Reuses KALSHI_API_KEY / KALSHI_RSA_PRIVATE_KEY above
# ----------------------------------------------------------
POLITICAL_TRADER_ENABLED=false
POLITICAL_TRADER_MAX_POSITION=15.00
POLITICAL_TRADER_MIN_SIGNAL=0.45
POLITICAL_TRADER_MIN_CONFIDENCE=0.60

# ----------------------------------------------------------
# Weather Trader — NWS-edge Kalshi weather prediction markets
# No additional API key required (NWS is free and public)
# Reuses KALSHI_API_KEY / KALSHI_RSA_PRIVATE_KEY above
# ----------------------------------------------------------
WEATHER_TRADER_ENABLED=false
WEATHER_TRADER_MAX_POSITION=20.00
WEATHER_TRADER_MIN_EDGE=0.10

# ----------------------------------------------------------
# Debug / internal
# ----------------------------------------------------------
TRADE_DEBUG=false    # true = SNS alert on every agent decision (verbose)
