# NEW: Environment variables for funding_rate module
# Copy to .env and fill in your actual credentials

# ============================================================================
# Coinbase API Authentication
# ============================================================================

# Your Coinbase API key name (full identifier from Coinbase Cloud)
# Format: organizations/{org_id}/apiKeys/{key_id}
COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/yyy

# Your EC P-256 private key in PEM format
# Keep this secret! Use AWS Secrets Manager in production.
# Format: -----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----
COINBASE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIIGlVmKzw3Zq...
-----END EC PRIVATE KEY-----"

# ============================================================================
# Funding Rate Strategy Parameters
# ============================================================================

# Enable/disable the module
FUNDING_RATE_ENABLED=false

# Maximum USD notional per position (e.g., $100 per pair)
FUNDING_RATE_MAX_POSITION=100.00

# Minimum annualized funding rate to enter (default 10%)
FUNDING_RATE_MIN_APR=0.10

# Annualized funding rate to exit (default 5%)
FUNDING_RATE_EXIT_APR=0.05

# Maximum % of spot balance to use per position (default 30%)
FUNDING_RATE_MAX_PCT_BALANCE=0.30

# Maximum simultaneous positions (default 3)
FUNDING_RATE_MAX_SIMULTANEOUS=3

# Maximum hold duration in days (default 30)
FUNDING_RATE_MAX_HOLD_DAYS=30

# Rebalance threshold (drift %, default 2%)
FUNDING_RATE_REBALANCE_THRESHOLD=0.02

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS region for DynamoDB and SNS
AWS_REGION=us-east-1

# SNS topic ARN for alerts (shared with other modules)
SENTINEL_SNS_ARN=arn:aws:sns:us-east-1:123456789012:trading-bot-alerts

# DynamoDB table names
FUNDING_RATE_OPPORTUNITIES_TABLE=funding-rate-opportunities
FUNDING_RATE_POSITIONS_TABLE=funding-rate-positions

# ============================================================================
# Lambda Execution Context (set automatically in Lambda env)
# ============================================================================

# AWS_LAMBDA_FUNCTION_NAME
# AWS_LAMBDA_FUNCTION_VERSION
# AWS_EXECUTION_ENV
